                  "spec": {
                    "hidden": false,
                    "query": {
                      "group": "prometheus",
                      "kind": "DataQuery",
                      "spec": {
                        "expr": "sum by (method, path, status) (rate(http_server_response_count_responses_total{service_name=\"droneedge\", status=~\"5..\"}[5m]))",
